{
  "name": "realsass-sass-back",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "npx prisma migrate deploy && node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "start:migrate": "npx prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "catalog:backend",
    "@nestjs/config": "catalog:backend",
    "@nestjs/core": "catalog:backend",
    "@nestjs/mapped-types": "catalog:backend",
    "@nestjs/platform-express": "catalog:backend",
    "@nestjs/swagger": "catalog:backend",
    "@nestjs/terminus": "catalog:backend",
    "@nestjs/throttler": "catalog:backend",
    "@nestjs/bullmq": "catalog:backend",
    "@nestjs/event-emitter": "catalog:backend",
    "@prisma/adapter-pg": "catalog:backend",
    "@prisma/client": "catalog:backend",
    "bcrypt": "catalog:backend",
    "bullmq": "catalog:backend",
    "class-transformer": "catalog:backend",
    "class-validator": "catalog:backend",
    "dotenv": "catalog:backend",
    "firebase-admin": "catalog:backend",
    "helmet": "catalog:backend",
    "ioredis": "catalog:backend",
    "joi": "catalog:backend",
    "pg": "catalog:backend",
    "reflect-metadata": "catalog:backend",
    "rxjs": "catalog:backend",
    "swagger-ui-express": "catalog:backend",
    "uuid": "catalog:backend",
    "@trpc/server": "catalog:backend",
    "zod": "catalog:backend"
  },
  "devDependencies": {
    "@eslint/eslintrc": "catalog:backend",
    "@eslint/js": "catalog:backend",
    "@nestjs/cli": "catalog:backend",
    "@nestjs/schematics": "catalog:backend",
    "@nestjs/testing": "catalog:backend",
    "@types/bcrypt": "catalog:backend",
    "@types/express": "catalog:backend",
    "@types/jest": "catalog:backend",
    "@types/node": "catalog:backend",
    "@types/supertest": "catalog:backend",
    "@types/uuid": "catalog:backend",
    "eslint": "catalog:backend",
    "eslint-config-prettier": "catalog:backend",
    "eslint-plugin-prettier": "catalog:backend",
    "globals": "catalog:backend",
    "jest": "catalog:backend",
    "prettier": "catalog:backend",
    "prisma": "catalog:backend",
    "source-map-support": "catalog:backend",
    "supertest": "catalog:backend",
    "ts-jest": "catalog:backend",
    "ts-loader": "catalog:backend",
    "ts-node": "catalog:backend",
    "tsconfig-paths": "catalog:backend",
    "typescript": "catalog:backend",
    "typescript-eslint": "catalog:backend"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}