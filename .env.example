# ================================
# DATABASE
# ================================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/real_estate_saas?schema=public"

# ================================
# FIREBASE ADMIN SDK
# Obtener desde: Firebase Console → Project Settings → Service Accounts → Generate new private key
# ================================
FIREBASE_PROJECT_ID="tu-proyecto-firebase"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com"
# IMPORTANTE: Copiar la private_key del JSON descargado incluyendo -----BEGIN...-----END-----
# En el .env, reemplazar saltos de línea con \n
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----"

# ================================
# APP
# ================================
NODE_ENV="development"
PORT=3000
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:5173"